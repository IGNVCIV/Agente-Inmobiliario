# ════════════════════════════════════════════════════════════
# Configuración del Agente Inmobiliario IA
# ════════════════════════════════════════════════════════════

# INSTRUCCIONES:
# 1. Copia este archivo a .env.
# 2. Reemplaza solo los valores que realmente uses en tu entorno local.
# 3. No subas .env al repositorio ni lo incluyas en evidencias públicas.
# 4. No pegues claves reales en capturas, logs ni documentación.

# ════════════════════════════════════════════════════════════
# Proveedor LLM principal: Ollama local en Docker
# ════════════════════════════════════════════════════════════

# Proveedor activo. Para la Fase 6, el proveedor principal es Ollama local.
LLM_PROVIDER=ollama

# URL base de Ollama compatible con OpenAI.
# En Docker Compose, usar el nombre del servicio:
OLLAMA_BASE_URL=http://ollama:11434/v1

# Si ejecutas la app fuera de Docker y Ollama corre en tu máquina local, puedes usar:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelo local descargado en Ollama.
OLLAMA_MODEL=llama3.2:3b

# ════════════════════════════════════════════════════════════
# Simulación referencial de costos OpenAI
# ════════════════════════════════════════════════════════════

# Este modelo se usa solo para estimar cuánto costaría una ejecución hipotética
# en OpenAI. No representa facturación real cuando el proveedor activo es Ollama.
OPENAI_SIM_MODEL=gpt-4o-mini

# ════════════════════════════════════════════════════════════
# Proveedores alternativos o de referencia
# ════════════════════════════════════════════════════════════

# OpenAI queda como alternativa o referencia, no como proveedor principal.
# Completar solo si se habilita explícitamente ese proveedor.
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-reemplazar-solo-en-env-local

# GitHub Models queda como alternativa o referencia.
# Completar solo si se implementa y habilita explícitamente ese proveedor.
GITHUB_MODEL=openai/gpt-4.1
# GITHUB_TOKEN=ghp-reemplazar-solo-en-env-local

# ════════════════════════════════════════════════════════════
# Banco Central de Chile para UF, opcional
# ════════════════════════════════════════════════════════════

# Necesario solo si se usa la integración de UF en tiempo real.
# Si no se configura, el sistema debe usar un fallback controlado.
BCCH_USER=tu_usuario_bcch
BCCH_PASS=tu_contraseña_bcch
BCCH_SERIE_UF=F063858

# ════════════════════════════════════════════════════════════
# Base de datos SQLite
# ════════════════════════════════════════════════════════════

# Ruta por defecto usada por el proyecto.
# DATABASE_PATH=backend/propiedades.db

# ════════════════════════════════════════════════════════════
# Logging
# ════════════════════════════════════════════════════════════

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Evitar DEBUG en evidencias si puede mostrar datos sensibles.
LOG_LEVEL=INFO
