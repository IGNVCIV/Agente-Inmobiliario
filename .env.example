# ════════════════════════════════════════════════════════════
# Configuración del Agente Inmobiliario IA
# ════════════════════════════════════════════════════════════

# INSTRUCCIONES:
# 1. Copia este archivo a .env (sin el sufijo .example)
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. Asegúrate de que .env esté en .gitignore (no comitear credenciales)

# ════════════════════════════════════════════════════════════
# OpenAI API (REQUERIDO)
# ════════════════════════════════════════════════════════════

# Tu clave API de OpenAI
# Obtén tu clave en: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Modelo de lenguaje a usar
# Opciones: gpt-4o-mini, gpt-4o, gpt-4-turbo, etc.
OPENAI_MODEL=gpt-4o-mini

# ════════════════════════════════════════════════════════════
# Banco Central de Chile (OPCIONAL)
# ════════════════════════════════════════════════════════════
# Necesario para obtener el valor de la UF en tiempo real
# Si no configuras estas variables, el sistema usará un fallback a SBIF

# Usuario del Banco Central de Chile (Serie Temporal)
BCCH_USER=tu_usuario_bcch

# Contraseña del Banco Central de Chile
BCCH_PASS=tu_contraseña_bcch

# Serie de la UF en el Banco Central
# F063858 es el código estándar para la UF
BCCH_SERIE_UF=F063858

# ════════════════════════════════════════════════════════════
# Configuración de Base de Datos (OPCIONAL)
# ════════════════════════════════════════════════════════════

# Ruta de la base de datos SQLite (por defecto: backend/propiedades.db)
# DATABASE_PATH=backend/propiedades.db

# ════════════════════════════════════════════════════════════
# Configuración de Logging (OPCIONAL)
# ════════════════════════════════════════════════════════════

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
